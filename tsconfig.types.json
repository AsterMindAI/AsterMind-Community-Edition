{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Node",
        "declaration": true,
        "emitDeclarationOnly": true,
        "declarationMap": false,
        "stripInternal": true,
        "rootDir": "src",
        "outDir": "dist",
        "skipLibCheck": true,
        "strict": true
    },
    "include": [
        "src/index.ts",
        "src/**/*.ts"
    ],
    "exclude": [
        "src/**/examples/**",
        "src/**/scripts/**",
        "node_examples",
        "examples",
        "tests",
        "public"
    ]
}